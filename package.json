{
  "name": "binectics-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "A global ecosystem connecting gyms, fitness trainers, dietitians, and wellness enthusiasts",
  "keywords": [
    "fitness",
    "gym",
    "wellness",
    "marketplace"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "api:sync": "openapi-typescript ${OPENAPI_SCHEMA_PATH:-../binectics-api/schema/openapi.json} -o src/lib/api/generated/schema.ts",
    "api:check": "npm run api:sync && git diff --exit-code -- src/lib/api/generated/schema.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@hookform/resolvers": "5.2.2",
    "@stripe/react-stripe-js": "6.0.0",
    "@stripe/stripe-js": "9.0.0",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/react-query": "5.99.0",
    "@tiptap/core": "3.23.6",
    "@tiptap/extension-link": "3.23.6",
    "@tiptap/extension-placeholder": "3.23.6",
    "@tiptap/extension-underline": "3.23.6",
    "@tiptap/pm": "3.23.6",
    "@tiptap/react": "3.23.6",
    "@tiptap/starter-kit": "3.23.6",
    "@types/qrcode": "1.5.6",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "dompurify": "3.3.3",
    "firebase": "12.16.0",
    "flutterwave-react-v3": "1.3.3",
    "jsqr": "1.4.0",
    "lucide-react": "0.575.0",
    "next": "16.1.5",
    "qrcode": "1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "7.72.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "husky": "9.1.7",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
